# ─── Cafe QR Delivery App — Environment Variables ────────────────────────────
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.

# ── Backend ───────────────────────────────────────────────────────────────────
# Base URL of the Cafe QR Java backend (no trailing slash).
# Used by server-side API routes (backendFetch) and client-side apiFetch.
NEXT_PUBLIC_API_BASE_URL=https://cafe-qr-backend.onrender.com/api

# ── Session signing (server-side only — NEVER expose to client) ───────────────
# HMAC-SHA256 secret used by lib/auth.js to sign & verify delivery_session
# cookies.  Must match the value used when the cookie was originally issued.
# Generate a strong value with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
INTERNAL_API_SECRET=replace_with_a_long_random_secret

# ── Mailer (server-side only) ─────────────────────────────────────────────────
# Gmail address and App Password used by lib/gmailMailer.js to send OTP emails.
# Create an App Password at: https://myaccount.google.com/apppasswords
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# ── Capacitor / Android build ─────────────────────────────────────────────────
# Set to 'true' when building the Android APK (enables Next.js static export).
# Leave 'false' for PWA / web deployment.
NEXT_PUBLIC_NATIVE_BUILD=false
